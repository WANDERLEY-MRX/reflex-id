generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  password            String?
  avatar              String?
  emailVerified       DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  role                String    @default("USER")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  skills              Skill[]
  activities          TimelineEvent[]
  projects            Project[]
  evidences           Evidence[]
  validations         Validation[]
  badges              UserBadge[]
  achievements        Achievement[]
  notifications       Notification[]
  comments            Comment[]
  reports             Report[]           @relation("reporter")
  membership          OrganizationMember[]
  schoolProfile       SchoolProfile[]
  verifiedEvents      TimelineEvent[] @relation("verifiedEvents")
  auditLogs           AuditLog[]
  permissions         UserPermission[]
  consentLogs         ConsentLog[]
  apiKeys             ApiKey[]
  analytics           Analytics[]
  verificationRequests VerificationRequest[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  slug        String   @unique
  bio         String?
  headline    String?
  location    String?
  website     String?
  github      String?
  linkedin    String?
  twitter     String?
  instagram   String?
  interests   String?
  goals       String?
  availability String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
}

model Skill {
  id        String    @id @default(cuid())
  name      String
  category  String
  userId    String
  level     Int       @default(1)
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model TimelineEvent {
  id             String    @id @default(cuid())
  userId         String
  title          String
  description    String?
  date           DateTime
  category       String
  attachments    Json?
  confidenceLevel String  @default("LOW")
  verifiedById   String?
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy User? @relation("verifiedEvents", fields: [verifiedById], references: [id])

  @@index([userId])
  @@index([category])
  @@index([date])
}

model Project {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  technologies    String
  images          Json?
  files           Json?
  links           Json?
  results         String?
  skillsAcquired  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

model Evidence {
  id                 String    @id @default(cuid())
  userId             String
  title              String
  description        String?
  type               String
  url                String?
  fileHash           String?
  timestamp          DateTime  @default(now())
  source             String?
  verificationStatus String    @default("PENDING")
  confidenceLevel    String    @default("LOW")
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files      EvidenceFile[]
  validations Validation[]
  comments   Comment[]
  badges     UserBadge[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([type])
}

model EvidenceFile {
  id         String   @id @default(cuid())
  evidenceId String
  filename   String
  mimeType   String
  size       Int
  hash       String
  url        String
  createdAt  DateTime @default(now())

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
}

model Validation {
  id              String    @id @default(cuid())
  evidenceId      String
  validatorId     String
  validatorType   String
  status          String    @default("PENDING")
  comment         String?
  confidenceLevel String    @default("LOW")
  createdAt       DateTime  @default(now())

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  validator User    @relation(fields: [validatorId], references: [id])

  @@index([evidenceId])
  @@index([validatorId])
  @@index([status])
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        String    @default("OTHER")
  logo        String?
  description String?
  website     String?
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  members     OrganizationMember[]
  schoolProfile SchoolProfile[]
  verificationRequests VerificationRequest[]

  @@index([slug])
  @@index([type])
}

model OrganizationMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model SchoolProfile {
  id             String   @id @default(cuid())
  orgId          String
  studentId      String
  grade          String?
  class          String?
  enrollmentYear Int?
  verified       Boolean  @default(false)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([orgId, studentId])
  @@index([orgId])
  @@index([studentId])
}

model Badge {
  id          String    @id @default(cuid())
  name        String
  description String?
  image       String?
  criteria    String?
  category    String
  level       String    @default("BRONZE")

  users UserBadge[]
}

model UserBadge {
  id         String    @id @default(cuid())
  userId     String
  badgeId    String
  awardedAt  DateTime  @default(now())
  evidenceId String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  evidence Evidence? @relation(fields: [evidenceId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Achievement {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  icon        String?
  unlockedAt  DateTime  @default(now())
  metadata    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  data      Json?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  evidenceId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
  @@index([userId])
}

model Report {
  id         String    @id @default(cuid())
  reporterId String
  targetId   String
  targetType String
  reason     String
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())

  reporter User @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
}

model VerificationRequest {
  id             String    @id @default(cuid())
  requesterId    String
  organizationId String
  status         String    @default("PENDING")
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  requester    User         @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([organizationId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  resource    String
  action      String

  users UserPermission[]

  @@index([resource])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json?

  @@index([name])
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  grantedBy    String?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  consented Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  key       String    @unique
  hash      String
  userId    String
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([hash])
}

model Analytics {
  id         String    @id @default(cuid())
  event      String
  userId     String?
  properties Json?
  timestamp  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([timestamp])
}
